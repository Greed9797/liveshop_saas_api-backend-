DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.wvmakdsjkuauwbcpubem.supabase.co:5432/postgres
JWT_SECRET=troque-por-segredo-forte-32-chars-min
JWT_EXPIRES_IN=15m
PORT=3001
NODE_ENV=development
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SANDBOX=true

# Para desenvolvimento local, use credenciais de um usuário de teste cadastrado no banco

# TikTok OAuth — obrigatórios para integração TikTok
TIKTOK_CLIENT_KEY=          # Obrigatório para integração TikTok
TIKTOK_CLIENT_SECRET=       # Obrigatório para integração TikTok
TIKTOK_REDIRECT_URI=        # Ex: https://api.seudominio.com/v1/tiktok/callback
TIKTOK_WEBHOOK_REQUIRE_SIGNATURE=false
TIKTOK_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# TikTok Live Connector — circuit breaker
TIKTOK_CB_THRESHOLD=5
TIKTOK_CB_WINDOW_MS=300000
TIKTOK_MAX_CONNECTORS=20

# Frontend URL pra redirect OAuth (TikTok OAuth callback)
FRONTEND_URL=https://app.livelab.com
